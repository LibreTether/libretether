{
	"$schema": "https://github.com/Skiley/runfile/releases/latest/download/v0.schema.json",
	"targets": {
		"build": {
			"commands": "cargo build {{ ARGS }}",
			"description": "Build the libretether-protocol library"
		},
		"check": {
			"commands": [
				"cargo fmt -- --check",
				"cargo clippy --all-targets -- -D warnings"
			],
			"description": "Format-check and lint just this crate"
		},
		"test": {
			"commands": "cargo test {{ ARGS }}",
			"description": "Run the libretether-protocol tests"
		}
	}
}
